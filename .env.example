# App
APP_ENV=development
PORT=8080
APP_NAME=go-boilerplate
TIMEZONE=UTC

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/boilerplate?sslmode=disable

# Auth
# Options: firebase | jwt
AUTH_MODE=firebase

# Firebase (required when AUTH_MODE=firebase)
# Path to service account JSON file or the JSON string itself
FIREBASE_CREDENTIALS=/path/to/service-account.json

# JWT (required when AUTH_MODE=jwt)
JWT_SECRET=change-me-in-production
JWT_LIFETIME_MINUTES=60
